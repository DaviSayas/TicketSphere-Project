# Base de dados
DATABASE_URL=sqlite:///./tickets.db

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Email outbound (SMTP - Mailpit por defeito)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=helpdesk@empresa.pt
SMTP_USER=
SMTP_PASSWORD=

# Email inbound (IMAP - Mailpit não tem IMAP, usa Dovecot ou conta real)
IMAP_HOST=localhost
IMAP_PORT=1143
IMAP_USER=support@empresa.pt
IMAP_PASSWORD=password
IMAP_USE_SSL=false

# Scheduler — disabled online (no real IMAP/SMTP server)
ENABLE_SCHEDULER=false
IMAP_POLL_MINUTES=2
SLA_CHECK_MINUTES=5

# CORS — allow all for online deployment
CORS_ORIGINS=*
